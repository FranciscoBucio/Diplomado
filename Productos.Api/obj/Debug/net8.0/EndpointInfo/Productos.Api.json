{
  "openapi": "3.0.1",
  "info": {
    "title": "Hola mundo (CRUD de productos)",
    "description": "CRUD de productos",
    "contact": {
      "name": "Francisco Bucio",
      "email": ""
    },
    "version": "v1"
  },
  "paths": {
    "/api/Productos": {
      "get": {
        "tags": [
          "Productos"
        ],
        "summary": "Obtener lista de productos disponibles",
        "responses": {
          "200": {
            "description": "Regresa la lista de productos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProductoDTO"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Productos"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoDTOIn"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoDTOIn"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProductoDTOIn"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Productos/{id}": {
      "get": {
        "tags": [
          "Productos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ProductoDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "encodedkey": {
            "type": "string",
            "format": "uuid"
          },
          "nombre": {
            "type": "string",
            "nullable": true
          },
          "descripcion": {
            "type": "string",
            "nullable": true
          },
          "precio": {
            "type": "number",
            "format": "double"
          },
          "imagenUrl": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ProductoDTOIn": {
        "required": [
          "descripcion",
          "nombre",
          "precio"
        ],
        "type": "object",
        "properties": {
          "encodedkey": {
            "type": "string",
            "format": "uuid"
          },
          "nombre": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "descripcion": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "precio": {
            "maximum": 350,
            "minimum": 25,
            "type": "number",
            "format": "double"
          },
          "imagenUrl": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}